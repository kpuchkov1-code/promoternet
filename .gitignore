# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# Jupyter
.ipynb_checkpoints/
*.ipynb_meta

# Data (reproducible from scripts/download_data.py)
data/raw/*
data/interim/*
data/processed/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# Model checkpoints
checkpoints/
*.pt
*.pth
*.bin
*.safetensors

# Reports figures (regeneratable)
reports/figures/*.png
reports/figures/*.pdf
!reports/figures/.gitkeep

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/

# Coverage
.coverage
htmlcov/
.pytest_cache/

# stray debug logs
saliency_out*.txt
figures_out*.txt

